### 3. Export Generation (XLSX/PDF)

**Excel Export** (using `excelize`):
```go
import "github.com/xuri/excelize/v2"

func ExportToExcel(cfdis []tenant.CFDI) ([]byte, error) {
    f := excelize.NewFile()
    sheet := "CFDIs"
    f.NewSheet(sheet)
    
    // Write headers
    f.SetCellValue(sheet, "A1", "UUID")
    f.SetCellValue(sheet, "B1", "Fecha")
    f.SetCellValue(sheet, "C1", "Total")
    
    // Write data rows
    for i, cfdi := range cfdis {
        row := i + 2
        f.SetCellValue(sheet, fmt.Sprintf("A%d", row), cfdi.UUID)
        f.SetCellValue(sheet, fmt.Sprintf("B%d", row), cfdi.Fecha.Format("2006-01-02"))
        f.SetCellValue(sheet, fmt.Sprintf("C%d", row), cfdi.Total)
    }
    
    buf, err := f.WriteToBuffer()
    if err != nil {
        return nil, err
    }
    return buf.Bytes(), nil
}
```

**S3 Upload + Presigned URL**:
```go
key := fmt.Sprintf("exports/%s/%s.xlsx", companyID, uuid.NewString())
_, err := s3Client.Upload(ctx, cfg.S3Export, key, bytes.NewReader(excelBytes))
if err != nil {
    return "", err
}

url, err := s3Client.PresignedGetURL(cfg.S3Export, key, 24*time.Hour)
if err != nil {
    return "", err
}
return url, nil
```

