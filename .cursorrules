## Common Patterns

### 1. CRUD Endpoints (Search/Create/Update/Delete)

**Search**:
```go
func (h *Handler) Search(w http.ResponseWriter, r *http.Request) {
    conn, _, err := h.tenantConn(r, true)
    if err != nil {
        response.InternalError(w, fmt.Sprintf("tenant session: %v", err))
        return
    }
    defer conn.Close()

    raw, _ := io.ReadAll(r.Body)
    params, _, _ := crud.ParseSearchBodyJSON(raw)
    
    result, err := crud.Search[tenant.Model](r.Context(), conn, params, modelMeta)
    if err != nil {
        response.InternalError(w, fmt.Sprintf("search: %v", err))
        return
    }
    
    response.WriteJSON(w, http.StatusOK, result)
}
```

**Create**:
```go
func (h *Handler) Create(w http.ResponseWriter, r *http.Request) {
    user, _ := auth.UserFromContext(r.Context())
    
    var req CreateRequest
    if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
        response.BadRequest(w, "invalid JSON")
        return
    }
    
    record := &control.Model{
        Identifier: uuid.NewString(),
        CreatedBy:  user.ID,
        CreatedAt:  time.Now(),
        UpdatedAt:  time.Now(),
    }
    
    _, err := h.database.Primary.NewInsert().Model(record).Exec(r.Context())
    if err != nil {
        response.InternalError(w, fmt.Sprintf("insert: %v", err))
        return
    }
    
    response.WriteJSON(w, http.StatusOK, record)
}
```

